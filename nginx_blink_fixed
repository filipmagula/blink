server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name blink.chupacabra.tech;

    ssl_certificate /etc/letsencrypt/live/blink.chupacabra.tech/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/blink.chupacabra.tech/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    location / {
        proxy_pass http://localhost:21337;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        client_max_body_size 0;
        proxy_request_buffering off;
        client_body_timeout 3600;
        proxy_read_timeout 3600;
        proxy_send_timeout 3600;
    }
}

server {
    if ($host = blink.chupacabra.tech) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    listen [::]:80;
    server_name blink.chupacabra.tech;
    return 404; # managed by Certbot
}
